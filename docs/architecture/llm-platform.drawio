        <mxCell id="t3" value="Autoscaling and telemetry" style="text;html=1;fontFamily=Helvetica;fontSize=22;fontStyle=1;fontColor=#1E293B;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="30" width="700" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t3b" value="KEDA scales on leading saturation signals, never on request count. Two metric families feed two dashboards." style="text;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#64748B;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="62" width="960" height="20" as="geometry" />
