        </mxCell>

        <mxCell id="pipe" value="Crossplane composition pipeline" style="rounded=1;absoluteArcSize=1;arcSize=16;shadow=1;verticalAlign=top;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#FAFAFF;strokeColor=#7C3AED;strokeWidth=1.5;fontColor=#1E293B;fontFamily=Helvetica;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="140" width="300" height="230" as="geometry" />
        </mxCell>
        <mxCell id="p1" value="function-environment-configs&#xa;(eks-environment)" style="rounded=1;absoluteArcSize=1;arcSize=10;shadow=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;strokeWidth=1.5;fontColor=#1E293B;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="pipe">
          <mxGeometry x="20" y="40" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="&lt;b&gt;function-kcl&lt;/b&gt;   target: Default&#xa;OCI crossplane-inference-service:0.8.2" style="rounded=1;absoluteArcSize=1;arcSize=10;shadow=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;strokeWidth=1.5;fontColor=#1E293B;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="pipe">
          <mxGeometry x="20" y="105" width="260" height="55" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="function-auto-ready" style="rounded=1;absoluteArcSize=1;arcSize=10;shadow=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;strokeWidth=1.5;fontColor=#1E293B;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="pipe">
          <mxGeometry x="20" y="175" width="260" height="40" as="geometry" />
        </mxCell>

        <mxCell id="always" value="Always rendered  —  7 objects" style="rounded=1;absoluteArcSize=1;arcSize=16;shadow=1;verticalAlign=top;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#F5F7FF;strokeColor=#6366F1;strokeWidth=1.5;fontColor=#1E293B;fontFamily=Helvetica;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="860" y="120" width="360" height="230" as="geometry" />
        </mxCell>
        <mxCell id="a1" value="Deployment  ·  Service :8000  ·  ServiceAccount&#xa;&#xa;ScaledObject  (KEDA — 3 triggers)&#xa;&#xa;CiliumNetworkPolicy  (default-deny;&#xa;egress = kube-dns ONLY)&#xa;&#xa;VMServiceScrape  ·  VMRule (2 SLO alerts)" style="text;html=1;align=left;verticalAlign=top;fontFamily=Helvetica;fontSize=12;fontColor=#1E293B;" vertex="1" parent="always">
          <mxGeometry x="18" y="36" width="330" height="180" as="geometry" />
        </mxCell>

        <mxCell id="gwon" value="if  gateway.enabled" style="rounded=1;absoluteArcSize=1;arcSize=16;shadow=1;verticalAlign=top;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#F5F7FF;strokeColor=#6366F1;strokeWidth=1.5;fontColor=#1E293B;fontFamily=Helvetica;fontSize=13;fontStyle=1;" vertex="1" parent="1">
