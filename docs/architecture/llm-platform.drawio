        <mxCell id="e-pv-csi" value="NodeStage / NodePublish" style="endArrow=classic;html=1;strokeColor=#33a02c;strokeWidth=2;fontSize=9;" edge="1" parent="1" source="pv-llm" target="efs-csi">
          <mxGeometry relative="1" as="geometry" />
