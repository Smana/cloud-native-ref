  <diagram name="2 — One claim, rendered" id="composition">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" page="1" pageWidth="1654" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="t2" value="InferenceService — what one claim renders" style="text;html=1;fontFamily=Helvetica;fontSize=22;fontStyle=1;fontColor=#1E293B;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="30" width="700" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t2b" value="A ~30-line claim becomes 7 objects at minimum, 16 with every feature on. Crossplane and function-kcl do the expansion." style="text;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#64748B;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="62" width="960" height="20" as="geometry" />
        </mxCell>

        <mxCell id="claim" value="&lt;b&gt;InferenceService&lt;/b&gt;  (claim)&#xa;cloud.ogenki.io/v1alpha1 · ns: llm&#xa;&#xa;model.repository / revision&#xa;model.preload.enabled  ← needed to boot&#xa;gpu.count&#xa;gateway.enabled + canaries[]&#xa;loraAdapters[]&#xa;engineArgs[]   (escape hatch)&#xa;scaling.{min, max, thresholds}" style="rounded=1;absoluteArcSize=1;arcSize=10;shadow=1;whiteSpace=wrap;html=1;fillColor=#EEF2FF;strokeColor=#6366F1;strokeWidth=1.5;fontColor=#1E293B;fontFamily=Helvetica;fontSize=12;align=left;spacingLeft=12;verticalAlign=top;spacingTop=10;" vertex="1" parent="1">
