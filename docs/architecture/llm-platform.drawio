        <mxCell id="e-fs-s3" value="write-through" style="endArrow=classic;startArrow=classic;html=1;strokeColor=#33a02c;strokeWidth=2;fontSize=9;" edge="1" parent="1" source="s3files-fs" target="s3-bucket">
