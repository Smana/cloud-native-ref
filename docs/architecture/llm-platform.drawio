        <mxCell id="e-is-pvc" value="mount with subPath&#xa;(load model from local NFS)" style="endArrow=classic;html=1;strokeColor=#33a02c;strokeWidth=2;fontSize=9;" edge="1" parent="1" source="is-grp" target="pvc-llm">
          <mxGeometry relative="1" as="geometry" />
