        <mxCell id="e-envoy-is" value="forward to vLLM&#xa;backend (X-VSR-Model)" style="endArrow=classic;html=1;strokeColor=#e31a1c;strokeWidth=2;dashed=1;fontSize=9;" edge="1" parent="1" source="gap-envoy" target="is-grp">
