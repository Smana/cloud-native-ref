        <mxCell id="e-sr-envoy" value="ext_proc gRPC" style="endArrow=classic;html=1;strokeColor=#e31a1c;strokeWidth=2;dashed=1;fontSize=9;" edge="1" parent="1" source="sr-pod" target="gap-envoy">
          <mxGeometry relative="1" as="geometry" />
