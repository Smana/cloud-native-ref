        <mxCell id="wt2" value="Model weights" style="text;html=1;align=left;fontFamily=Helvetica;fontSize=17;fontStyle=1;fontColor=#1E293B;" vertex="1" parent="1">
          <mxGeometry x="60" y="960" width="240" height="25" as="geometry" />
        </mxCell>
        <mxCell id="wnote" value="&lt;b&gt;Weights never transit the serving pod.&lt;/b&gt;  It has no internet egress at all — it cannot reach HuggingFace even in principle.&#xa;A claim with no preload (and no subPath that another claim already filled) starts with an empty /models and never boots." style="text;html=1;align=left;fontFamily=Helvetica;fontSize=12;fontColor=#DC2626;" vertex="1" parent="1">
          <mxGeometry x="60" y="995" width="1100" height="45" as="geometry" />
        </mxCell>

