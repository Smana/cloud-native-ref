        <mxCell id="e-ow-sr" value="POST /v1/chat/completions" style="endArrow=classic;html=1;strokeColor=#1f78b4;strokeWidth=2;fontSize=9;" edge="1" parent="1" source="openwebui" target="sr-pod">
          <mxGeometry relative="1" as="geometry" />
