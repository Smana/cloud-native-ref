        <mxCell id="eppon" value="if  gateway.endpointPicker.enabled   (off today)" style="rounded=1;absoluteArcSize=1;arcSize=16;shadow=1;verticalAlign=top;container=1;pointerEvents=0;whiteSpace=wrap;html=1;dashed=1;fillColor=#F8FAFC;strokeColor=#94A3B8;strokeWidth=1.5;fontColor=#64748B;fontFamily=Helvetica;fontSize=13;fontStyle=1;" vertex="1" parent="1">
