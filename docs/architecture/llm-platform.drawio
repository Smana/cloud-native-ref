        <mxCell id="s3-bucket" value="S3 bucket&#xa;eu-west-3-ogenki-llm-models&#xa;(versioning ON,&#xa;EventBridge sync)" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#7AA116;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;" vertex="1" parent="storage-grp">
          <mxGeometry x="900" y="60" width="78" height="78" as="geometry" />
        </mxCell>
        <mxCell id="s3-iam" value="IAM&#xa;s3files_service role&#xa;(trust: elasticfilesystem.amazonaws.com)" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.identity_and_access_management_iam;" vertex="1" parent="storage-grp">
          <mxGeometry x="1080" y="60" width="78" height="78" as="geometry" />
        </mxCell>

        <mxCell id="storage-eb" value="EventBridge  •  Pod Identity Associations bind csi-controller-sa AND csi-node-sa to csi_driver IAM role (AmazonEFSCSIDriverPolicy + AmazonS3FilesCSIDriverPolicy)" style="text;html=1;align=center;fontSize=9;fontStyle=2;fontColor=#33a02c;" vertex="1" parent="storage-grp">
          <mxGeometry x="900" y="170" width="340" height="50" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- GitOps strip                                                  -->
        <!-- ============================================================ -->
        <mxCell id="gitops-grp" value="GitOps source of truth (drives every K8s resource above)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2dd;strokeColor=#ff7f00;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;dashed=1;" vertex="1" parent="aws-vpc">
          <mxGeometry x="160" y="1340" width="1280" height="100" as="geometry" />
        </mxCell>

        <mxCell id="git-repo" value="GitHub  •  Smana/cloud-native-ref&#xa;branch wip/self-hosted-llm-platform-draft" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ff7f00;fontSize=10;align=center;" vertex="1" parent="gitops-grp">
          <mxGeometry x="40" y="40" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ghcr" value="ghcr.io/smana/cloud-native-ref&#xa;OCI: KCL composition modules&#xa;(crossplane-app, crossplane-inference-service)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ff7f00;fontSize=9;align=center;" vertex="1" parent="gitops-grp">
          <mxGeometry x="360" y="40" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="gops-flow" value="Flux pulls Git → Kustomize / HelmRelease → applies&#xa;Crossplane reconciles XR claims → renders K8s + AWS managed resources" style="text;html=1;align=center;fontSize=10;fontColor=#ff7f00;fontStyle=2;" vertex="1" parent="gitops-grp">
          <mxGeometry x="680" y="45" width="540" height="40" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- Bottom: opentofu / openbao stripe                              -->
        <!-- ============================================================ -->
        <mxCell id="tofu-grp" value="Out-of-band (provisioned by Terramate / OpenTofu before EKS / Flux)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#666666;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="aws-region">
          <mxGeometry x="40" y="1500" width="1500" height="120" as="geometry" />
        </mxCell>

        <mxCell id="tofu-net" value="opentofu/network&#xa;━━━━━━━━&#xa;VPC, subnets,&#xa;Tailscale, Route53" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=10;align=center;" vertex="1" parent="tofu-grp">
          <mxGeometry x="40" y="40" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="tofu-bao" value="opentofu/openbao&#xa;━━━━━━━━&#xa;OpenBao cluster&#xa;PKI, secrets" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=10;align=center;" vertex="1" parent="tofu-grp">
          <mxGeometry x="280" y="40" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="tofu-eks" value="opentofu/eks/init + configure&#xa;━━━━━━━━━━━━━━━&#xa;EKS cluster, Cilium,&#xa;Flux Operator + Instance" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=10;align=center;" vertex="1" parent="tofu-grp">
          <mxGeometry x="520" y="40" width="240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="tofu-llm" value="opentofu/llm-platform&#xa;━━━━━━━━━━━━━━━&#xa;S3 Files filesystem + AP&#xa;EFS CSI IAM + Pod Identities" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=10;align=center;" vertex="1" parent="tofu-grp">
          <mxGeometry x="780" y="40" width="240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="tofu-note" value="Terramate orchestrates these in sequence.  After all four are applied, Flux takes over." style="text;html=1;align=center;fontSize=9;fontStyle=2;fontColor=#666666;" vertex="1" parent="tofu-grp">
          <mxGeometry x="1040" y="55" width="440" height="40" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- EDGES                                                         -->
        <!-- ============================================================ -->

        <!-- request flow: user → tailnet → router → gateway → openwebui → semantic-router -->
        <mxCell id="e-user-tn" value="" style="endArrow=classic;html=1;strokeColor=#1f78b4;strokeWidth=2;" edge="1" parent="1" source="user" target="ts-tailnet">
