        <mxCell id="e-gw-ow" value="" style="endArrow=classic;html=1;strokeColor=#1f78b4;strokeWidth=2;" edge="1" parent="1" source="httproute-ow" target="openwebui">
          <mxGeometry relative="1" as="geometry" />
