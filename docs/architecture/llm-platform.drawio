          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- model-weights flow: preload → PVC → PV → CSI → S3 Files → S3 -->
        <mxCell id="e-preload-pvc" value="mount with subPath" style="endArrow=classic;html=1;strokeColor=#33a02c;strokeWidth=2;fontSize=9;" edge="1" parent="1" source="preload" target="pvc-llm">
          <mxGeometry relative="1" as="geometry" />
