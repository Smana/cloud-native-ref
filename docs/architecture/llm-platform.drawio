        <mxCell id="cgw" value="&lt;b&gt;Cilium Gateway&lt;/b&gt;&#xa;platform-tailscale-general · ns infrastructure&#xa;https :443 — llm.priv.cloud.ogenki.io" style="rounded=1;absoluteArcSize=1;arcSize=10;shadow=1;whiteSpace=wrap;html=1;fillColor=#E0E7FF;strokeColor=#6366F1;strokeWidth=1.5;fontColor=#1E293B;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="360" width="270" height="80" as="geometry" />
        </mxCell>

        <mxCell id="svc" value="&lt;b&gt;Service ai-gateway :8080&lt;/b&gt;&#xa;ns: envoy-gateway-system&#xa;in-cluster clients skip Tailscale and hit it directly" style="rounded=1;absoluteArcSize=1;arcSize=10;shadow=1;whiteSpace=wrap;html=1;fillColor=#E0E7FF;strokeColor=#6366F1;strokeWidth=1.5;fontColor=#1E293B;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
