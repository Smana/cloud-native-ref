        <mxCell id="e-csi-fs" value="mount.nfs4 (TCP 2049)" style="endArrow=classic;html=1;strokeColor=#33a02c;strokeWidth=2;fontSize=9;" edge="1" parent="1" source="efs-csi" target="s3files-fs">
