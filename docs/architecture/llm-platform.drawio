        <mxCell id="keda" value="KEDA  —  ScaledObject &amp;lt;claim&amp;gt;" style="rounded=1;absoluteArcSize=1;arcSize=16;shadow=1;verticalAlign=top;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#FFFBEB;strokeColor=#F59E0B;strokeWidth=1.5;fontColor=#1E293B;fontFamily=Helvetica;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="330" y="400" width="700" height="300" as="geometry" />
        </mxCell>
        <mxCell id="k0" value="defaults: min 1  ·  max 3  ·  poll 15s  ·  cooldown 300s          —          three triggers, OR-combined" style="text;html=1;align=left;fontFamily=Helvetica;fontSize=12;fontColor=#64748B;" vertex="1" parent="keda">
          <mxGeometry x="20" y="34" width="660" height="20" as="geometry" />
        </mxCell>
        <mxCell id="k1" value="① batch saturation  —  threshold 0.7&#xa;max(vllm:num_requests_running{model_name=&quot;X&quot;}) / scalar(vector(max-num-seqs))" style="rounded=1;absoluteArcSize=1;arcSize=10;shadow=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#F59E0B;strokeWidth=1.5;fontColor=#1E293B;fontFamily=Helvetica;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="keda">
          <mxGeometry x="20" y="65" width="660" height="60" as="geometry" />
        </mxCell>
        <mxCell id="k2" value="② KV-cache pressure  —  threshold 0.6&#xa;max(vllm:kv_cache_usage_perc{model_name=&quot;X&quot;})" style="rounded=1;absoluteArcSize=1;arcSize=10;shadow=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#F59E0B;strokeWidth=1.5;fontColor=#1E293B;fontFamily=Helvetica;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="keda">
          <mxGeometry x="20" y="135" width="660" height="60" as="geometry" />
        </mxCell>
        <mxCell id="k3" value="③ queue depth  —  threshold 8&#xa;max(vllm:num_requests_waiting{model_name=&quot;X&quot;})" style="rounded=1;absoluteArcSize=1;arcSize=10;shadow=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#F59E0B;strokeWidth=1.5;fontColor=#1E293B;fontFamily=Helvetica;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="keda">
