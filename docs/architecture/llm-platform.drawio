        </mxCell>
        <mxCell id="g1" value="Backend  &amp;lt;claim&amp;gt;-direct&#xa;AIServiceBackend  &amp;lt;claim&amp;gt;&#xa;   + one per canary  (-canary-N)&#xa;AIGatewayRoute&#xa;   readiness-latched: rendered only once&#xa;   the Deployment reports Available" style="text;html=1;align=left;verticalAlign=top;fontFamily=Helvetica;fontSize=12;fontColor=#1E293B;" vertex="1" parent="gwon">
          <mxGeometry x="18" y="34" width="330" height="130" as="geometry" />
