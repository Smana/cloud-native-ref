        </mxCell>

        <mxCell id="dp" value="Envoy data-plane pod  —  ns: envoy-gateway-system" style="rounded=1;absoluteArcSize=1;arcSize=16;shadow=1;verticalAlign=top;container=1;pointerEvents=0;whiteSpace=wrap;html=1;fillColor=#FAFAFF;strokeColor=#6366F1;strokeWidth=1.5;fontColor=#1E293B;fontFamily=Helvetica;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="510" width="620" height="400" as="geometry" />
        </mxCell>
        <mxCell id="f0" value="&lt;b&gt;① SecurityPolicy — apiKeyAuth&lt;/b&gt;&#xa;Authorization: Bearer &amp;lt;key&amp;gt;   ·   sanitize: true&#xa;targets the Gateway, so every route inherits it" style="rounded=1;absoluteArcSize=1;arcSize=10;shadow=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;strokeWidth=1.5;fontColor=#1E293B;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="dp">
          <mxGeometry x="30" y="45" width="560" height="65" as="geometry" />
        </mxCell>
        <mxCell id="f1" value="&lt;b&gt;② http_filters[0] — semantic-router ext_proc&lt;/b&gt;&#xa;gRPC / HTTP2, request body BUFFERED&#xa;runs on EVERY request; rewrites only model: MoM | auto" style="rounded=1;absoluteArcSize=1;arcSize=10;shadow=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#F59E0B;strokeWidth=1.5;fontColor=#1E293B;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="dp">
          <mxGeometry x="30" y="130" width="560" height="70" as="geometry" />
        </mxCell>
        <mxCell id="f2" value="&lt;b&gt;③ AI Gateway extproc (sidecar)&lt;/b&gt;&#xa;derives header x-ai-eg-model from body.model&#xa;emits gen_ai_* metrics on :1064" style="rounded=1;absoluteArcSize=1;arcSize=10;shadow=1;whiteSpace=wrap;html=1;fillColor=#EEF2FF;strokeColor=#6366F1;strokeWidth=1.5;fontColor=#1E293B;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="dp">
          <mxGeometry x="30" y="220" width="560" height="70" as="geometry" />
        </mxCell>
        <mxCell id="f3" value="&lt;b&gt;④ AIGatewayRoute&lt;/b&gt;   match x-ai-eg-model → AIServiceBackend&#xa;the base rule carries the canary weights (modelNameOverride)" style="rounded=1;absoluteArcSize=1;arcSize=10;shadow=1;whiteSpace=wrap;html=1;fillColor=#E0E7FF;strokeColor=#6366F1;strokeWidth=1.5;fontColor=#1E293B;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="dp">
          <mxGeometry x="30" y="310" width="560" height="60" as="geometry" />
        </mxCell>

        <mxCell id="sr" value="&lt;b&gt;vllm-semantic-router&lt;/b&gt;&#xa;ns: llm   ·   ext_proc gRPC :50051&#xa;&#xa;Rewrites body.model in place:&#xa;MoM → a concrete fleet model.&#xa;&#xa;An explicit xplane-* model passes&#xa;through untouched." style="rounded=1;absoluteArcSize=1;arcSize=10;shadow=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#F59E0B;strokeWidth=1.5;fontColor=#1E293B;fontFamily=Helvetica;fontSize=12;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="920" y="590" width="300" height="160" as="geometry" />
        </mxCell>
        <mxCell id="srn" value="An EnvoyPatchPolicy (raw xDS JSONPatch) inserts this&#xa;filter at index 0. It MUST run before ③, because ③&#xa;derives the routing header from the body it rewrites —&#xa;and EnvoyExtensionPolicy can only append, never prepend." style="text;html=1;align=left;fontFamily=Helvetica;fontSize=11;fontColor=#64748B;" vertex="1" parent="1">
          <mxGeometry x="920" y="762" width="360" height="70" as="geometry" />
        </mxCell>

        <mxCell id="be" value="&lt;b&gt;Backend + AIServiceBackend&lt;/b&gt;&#xa;&amp;lt;claim&amp;gt;-direct → &amp;lt;claim&amp;gt;.llm.svc:8000&#xa;one extra AIServiceBackend per canary" style="rounded=1;absoluteArcSize=1;arcSize=10;shadow=1;whiteSpace=wrap;html=1;fillColor=#E0E7FF;strokeColor=#6366F1;strokeWidth=1.5;fontColor=#1E293B;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="240" y="970" width="330" height="70" as="geometry" />
        </mxCell>

        <mxCell id="epp" value="&lt;b&gt;InferencePool + endpoint picker&lt;/b&gt;&#xa;EPP ext_proc :9002 — picks the least-loaded replica&#xa;opt-in · OFF on every claim today" style="rounded=1;absoluteArcSize=1;arcSize=10;dashed=1;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#94A3B8;strokeWidth=1.5;fontColor=#64748B;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
