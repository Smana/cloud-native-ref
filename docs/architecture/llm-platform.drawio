        <mxCell id="vm" value="VictoriaMetrics&#xa;vmsingle :8428&#xa;ns: observability" style="shape=cylinder3;boundedLbl=1;backgroundOutline=1;shadow=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;strokeWidth=1.5;fontColor=#1E293B;fontFamily=Helvetica;fontSize=12;" vertex="1" parent="1">
