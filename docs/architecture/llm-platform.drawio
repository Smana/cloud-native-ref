        <mxCell id="pr1" value="Job  &amp;lt;claim&amp;gt;-preload-&amp;lt;rev&amp;gt;  (one-shot, TTL 24h)&#xa;CiliumNetworkPolicy  &amp;lt;claim&amp;gt;-preload&#xa;   the ONLY workload granted world:443" style="text;html=1;align=left;verticalAlign=top;fontFamily=Helvetica;fontSize=12;fontColor=#1E293B;" vertex="1" parent="pre">
          <mxGeometry x="18" y="34" width="330" height="70" as="geometry" />
